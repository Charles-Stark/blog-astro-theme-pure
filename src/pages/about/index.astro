---
import { Button, Collapse, Spoiler, Timeline } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import Substats from '@/components/about/Substats.astro'
import ToolSection from '@/components/about/ToolSection.astro'

const headings = [
  { depth: 2, slug: 'hobbies', text: 'Hobbies' },
  { depth: 2, slug: 'tools', text: 'Tools' },
  { depth: 2, slug: 'social-networks', text: 'Social Networks' },
  // { depth: 2, slug: 'gossips', text: 'Gossips' },
  { depth: 2, slug: 'about-blog', text: 'About Blog' }
]
---

<PageLayout title='About' {headings} comment>
  <p>Software Engineer / Developer / Car Enthusiast</p>
  <p>
    Currently working as a full-stack software engineer. Skilled in both frontend and backend development, with a strong focus on web technologies. Passionate about building efficient and user-friendly applications.
  </p>
  <p>
    Motto: <Spoiler>Put a ding in the universe.</Spoiler>
  </p>
  <!-- <Button title='Sponsor Me' class='w-fit' href='/projects#sponsorship' variant='ahead' /> -->

  {/* general-talk */}
  <h2 id='hobbies'>Hobbies</h2>
  <ul>
    <li><span class='font-bold'>Coding: </span>Love coding and building stuff.</li>
    <li>
      <span class='font-bold'>Cars: </span>Passionate about cars and racing. EVs are excluded for sure.
    </li>
    <li><span class='font-bold'>Gaming: </span>GTA5/OL, Sim racing (Assetto Corsa, Forza Horizon, etc), ATS, SnowRunner... Mostly car related. Got a Fanatec DD2 base and a 918 RSR wheel.</li>
  </ul>

  {/* tools */}
  <h2 id='tools'>Tools</h2>
  <p>I use these a lot:</p>
  <ToolSection
    class='mb-5'
    title='Productivity'
    tools={[
      {
        name: 'Chrome',
        description: 'Browser',
        href: 'https://www.google.com/chrome/',
        icon: import('@/assets/tools/chrome.svg?raw')
      },
      {
        name: 'Obsidian',
        description: 'Note Taking',
        href: 'https://obsidian.md',
        icon: import('@/assets/tools/obsidian.svg?raw')
      },
      {
        name: 'ChatGPT',
        description: 'AI',
        href: 'https://chatgpt.com',
        icon: import('@/assets/tools/chatgpt.svg?raw')
      },
      {
        name: 'Gemini',
        description: 'AI',
        href: 'https://gemini.google.com',
        icon: import('@/assets/tools/gemini.svg?raw')
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='Dev'
    tools={[
      {
        name: 'VS Code',
        description: 'Editor',
        href: 'https://code.visualstudio.com/',
        icon: import('@/assets/tools/vscode.svg?raw')
      },
      {
        name: 'Jetbrains',
        description: 'The best IDE provider',
        href: 'https://www.jetbrains.com/',
        icon: import('@/assets/tools/jetbrains.svg?raw')
      },
      {
        name: 'Neovim',
        description: 'Editor',
        href: 'https://neovim.io/',
        icon: import('@/assets/tools/neovim.svg?raw')
      },
      {
        name: 'Xcode',
        description: 'Apple',
        href: 'https://developer.apple.com/xcode/',
        icon: import('@/assets/tools/xcode.svg?raw')
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='OS'
    tools={[
      {
        name: 'macOS',
        description: 'MacBook Pro M1',
        href: 'https://www.apple.com/os/macos/',
        icon: import('@/assets/tools/apple.svg?raw')
      },
      {
        name: 'Windows 10',
        description: 'Custom PC',
        href: 'https://www.microsoft.com/windows/',
        icon: import('@/assets/tools/windows10.svg?raw')
      },
      {
        name: 'Debian 12',
        description: 'Server',
        href: 'https://www.debian.org/',
        icon: import('@/assets/tools/debian.svg?raw')
      },
      {
        name: 'Ubuntu 22.04',
        description: 'Server',
        href: 'https://ubuntu.com/',
        icon: import('@/assets/tools/ubuntu.svg?raw')
      }
    ]}
  />

  {/* social-networks */}
  <h2 id='social-networks'>Social Networks</h2>
  <p>
    <!-- Lorem ipsum -->
  </p>
  <Substats
    stats={[
      {
        platform: 'GitHub',
        icon: 'github',
        link: 'https://github.com/Charles-Stark',
        text: 'followers',
        api: 'github/Charles-Stark'
      },
      {
        platform: 'X',
        icon: 'x',
        link: 'https://x.com/charlesstark_',
        text: 'followers',
        api: 'x/charlesstark_'
      }
    ]}
  />

  {/* gossips */}
  <!-- <h2 id='gossips'>Gossips</h2>
  <Collapse title='Lorem ipsum'>
    Lorem ipsum dolor sit amet, vidit suscipit at mei. Quem denique mea id. Usu ei regione indoctum
    dissentiunt, cu meliore fuisset mei, vel quod voluptua ne. Ex dicat impedit mel, at eum oratio
    possit voluptatum.
  </Collapse> -->

  {/* about-blog */}
  <h2 id='about-blog'>About Blog</h2>
  <p>Website history:</p>
  <Timeline
    events={[
      {
        date: '2026-03-28',
        content: 'Made some updates'
      },
      {
        date: '2025-03-30',
        content: 'Deployed to Cloudflare Pages for the first time'
      },
      {
        date: '2025-03-28',
        content: 'Forked from <a href="https://github.com/cworld1/astro-theme-pure" target="_blank">Astro Theme Pure</a> and started tweaking'
      }
    ]}
  />
  <p>
    The smooth operation and personalized customization of website also rely on the resources and
    technical support provided by the following excellent projects/service providers:
  </p>
  <ul>
    <li>Domain: <a href='https://www.cloudflare.com/products/registrar/' target='_blank'>Cloudflare Registrar</a></li>
    <li>
      Framework & Theme: <a href='https://astro.build/' target='_blank'>Astro</a> + <a
        href='https://github.com/cworld1/astro-theme-pure'
        target='_blank'>Astro Theme Pure</a
      >
    </li>
    <li>
      Site hosting: <a href='https://pages.cloudflare.com/' target='_blank'>Cloudflare Pages</a>
    </li>
    <!-- <li>
      CI/CD: <a href='https://vercel.com/workflow' target='_blank'>Vercel Workflow</a>
    </li> -->
    <li>Comment system: <a href='https://waline.js.org' target='_blank'>Waline</a></li>
    <!-- <li>
      Visits: <a href='https://supabase.com/' target='_blank'>Supabase</a> +
      <a href='https://waline.js.org/' target='_blank'>Waline</a>
    </li> -->
    <li>
      Other statistics: <a href='https://github.com/spencerwooo/substats' target='_blank'
        >Substats</a
      >
    </li>
  </ul>
</PageLayout>
